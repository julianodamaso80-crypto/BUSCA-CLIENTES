{
    "name": "theme",
    "version": "1.0.0",
    "description": "Tailwind CSS for Django project",
    "scripts": {
        "start": "npm run dev",
        "build": "tailwindcss -i ./src/styles.css -o ../static/css/dist/styles.css --minify",
        "dev": "tailwindcss -i ./src/styles.css -o ../static/css/dist/styles.css --watch"
    },
    "devDependencies": {
        "tailwindcss": "^3.4.0"
    }
}
